# GitHub Personal Access Tokens
# Add your GitHub PATs here. At least one is required.
PAT_1=your_github_pat_here

# PAT_2=optional_second_token
# PAT_3=optional_third_token

# Optional: Override cache duration (in seconds). Set to 0 to disable.
# CACHE_SECONDS=86400

# Optional: Whitelist specific usernames (comma-separated)
# WHITELIST=username1,username2

# Optional: Whitelist specific gist IDs (comma-separated)
# GIST_WHITELIST=gist_id_1,gist_id_2

# Optional: Exclude repositories from stats (comma-separated)
# EXCLUDE_REPO=repo1,repo2

# Optional: Fetch all pages of stars (may increase API usage)
# FETCH_MULTI_PAGE_STARS=false
