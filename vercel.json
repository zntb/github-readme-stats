{
  "functions": {
    "api/*.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/url-builder.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/url-builder",
      "destination": "/api/url-builder"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "https://github.com/zntb/github-readme-stats"
    }
  ]
}